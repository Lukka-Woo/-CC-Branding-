{
  "brand": {
    "name": "“未来方舟”",
    "tagline": "Intelligence · Efficiency · Trust · Sustainability",
    "tone": "professional, enterprise, intelligent, restrained"
  },

  "colors": {
    "background": {
      "page":    "#F8FAFC",
      "neutral": "#FAFAFA",
      "surface": "#FFFFFF"
    },
    "text": {
      "primary":   "#101828",
      "secondary": "#475467"
    },
    "primary": {
      "500": "#3EC99E",
      "600": "#319E7C",
      "200": "#B8EDD8",
      "100": "#EAFAF5"
    },
    "secondary": {
      "500": "#C8E13C",
      "200": "#DBE89A",
      "100": "#F8FBE7"
    },
    "neutral": {
      "900": "#0E1216",
      "700": "#3D444A",
      "400": "#8A9199",
      "200": "#D0D5DD",
      "100": "#F2F3F5",
      "50": "#F8FAFC",
      "0": "#FFFFFF"
    },
    "semantic": {
      "success": "#5CC13C",
      "warning": "#F3B021",
      "danger": "#F12D2D"
    },
    "supplement": {
      "teal": "#3CC5CF",
      "purple": "#8255E1",
      "blue": "#007BFF",
      "orange": "#FFB928"
    }
  },

  "typography": {
    "fontFamily": {
      "cn": "Alibaba_PuHuiTi_2.0 SC, PingFang SC, 'Microsoft YaHei', sans-serif",
      "en": "Inter, SF Pro, -apple-system, BlinkMacSystemFont, sans-serif",
      "mono": "JetBrains Mono, SF Mono, 'Cascadia Code', monospace"
    },
    "fontWeight": {
      "light": 300,
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "scale": {
      "display1": { "size": 64, "weight": "bold", "lineHeight": 1.10, "letterSpacing": "-0.02em" },
      "display2": { "size": 56, "weight": "bold", "lineHeight": 1.15, "letterSpacing": "-0.01em" },
      "display3": { "size": 48, "weight": "semibold", "lineHeight": 1.20 },
      "h1":       { "size": 40, "weight": "semibold", "lineHeight": 1.25 },
      "h2":       { "size": 32, "weight": "medium", "lineHeight": 1.25 },
      "h3":       { "size": 24, "weight": "semibold", "lineHeight": 1.25 },
      "h4":       { "size": 20, "weight": "medium", "lineHeight": 1.25 },
      "h5":       { "size": 18, "weight": "medium", "lineHeight": 1.25 },
      "h6":       { "size": 16, "weight": "medium", "lineHeight": 1.25 },
      "bodyLarge": { "size": 18, "weight": "regular", "lineHeight": 1.50 },
      "body1":    { "size": 16, "weight": "regular", "lineHeight": 1.50 },
      "body2":    { "size": 14, "weight": "regular", "lineHeight": 1.50 },
      "body3":    { "size": 12, "weight": "regular", "lineHeight": 1.50 },
      "caption":  { "size": 11, "weight": "regular", "lineHeight": 1.40 },
      "small":    { "size": 10, "weight": "regular", "lineHeight": 1.30 }
    },

    "ppt": {
      "_note": "PPT 专属字号体系（单位 pt，canvas 13.33\"×7.50\"）。所有字号以参考文件 508mm 宽 canvas 实测值等比缩放（×0.666）后取整。",
      "roles": {
        "eyebrow":          { "size": 10, "bold": false, "color": "$colors.neutral.400" },
        "slideTitle":       { "size": 26, "bold": true,  "color": "$colors.neutral.900" },
        "slideSubtitle":    { "size": 12, "bold": false, "color": "$colors.neutral.400" },
        "slideLabel":       { "size":  9, "bold": false, "color": "$colors.neutral.400" },

        "coverTitle":       { "size": 42, "bold": true,  "color": "gradient:title" },
        "coverTitleLight":  { "size": 44, "bold": true,  "lineSpacingPt": 52, "color": "gradient:title" },
        "coverSubtitle":    { "size": 16, "bold": false, "color": "$colors.neutral.900" },
        "coverMeta":        { "size": 12, "bold": false, "color": "$colors.neutral.400" },
        "coverTagline":     { "size": 11, "bold": false, "color": "$colors.neutral.400" },
        "coverMetaValue":   { "size": 16, "bold": false, "color": "$colors.neutral.900" },
        "coverMetaLabel":   { "size": 13, "bold": false, "color": "$colors.neutral.400" },

        "sectionBigNum":    { "size": 260, "bold": true, "color": "$colors.neutral.900", "_note": "参考 390pt@508mm → 260pt@338mm，仅装饰用" },
        "sectionChapterLabel": { "size": 13, "bold": false, "color": "$colors.primary.100" },
        "sectionTitle":     { "size": 60, "bold": true,  "lineSpacingPt": 72, "color": "$colors.neutral.0", "_note": "参考 90pt@508mm → 60pt@338mm" },
        "sectionSubtitle":  { "size": 14, "bold": false, "color": "$colors.primary.100" },
        "sectionSidebarHeader":  { "size": 11, "bold": false, "color": "$colors.primary.100" },
        "sectionSidebarItem":    { "size": 13, "bold": false, "color": "$colors.neutral.0" },

        "tocChapterNum":    { "size": 44, "bold": true,  "color": "$colors.primary.500" },
        "tocChapterTitle":  { "size": 22, "bold": true,  "color": "$colors.neutral.900" },
        "tocChapterSub":    { "size": 12, "bold": false, "color": "$colors.neutral.400" },

        "bodyBullet":       { "size": 17, "bold": false, "lineSpacingPt": 21, "spaceBeforePt": 8, "bulletChar": "•", "color": "$colors.neutral.700" },
        "bodyText":         { "size": 16, "bold": false, "lineSpacingPt": 26, "color": "$colors.neutral.700" },
        "bodySmall":        { "size": 13, "bold": false, "lineSpacingPt": 20, "color": "$colors.neutral.700" },

        "colTitle":         { "size": 13, "bold": true,  "color": "$colors.primary.500" },
        "colBody":          { "size": 14, "bold": false, "lineSpacingPt": 22, "color": "$colors.neutral.700" },

        "cardTag":          { "size":  9, "bold": true  },
        "cardTitle":        { "size": 16, "bold": true,  "color": "$colors.neutral.900" },
        "cardBody":         { "size": 13, "bold": false, "lineSpacingPt": 20, "color": "$colors.neutral.700" },

        "statValue":        { "size": 44, "bold": true  },
        "statLabel":        { "size": 14, "bold": true,  "color": "$colors.neutral.900" },
        "statDesc":         { "size": 12, "bold": false, "lineSpacingPt": 18, "color": "$colors.neutral.400" },

        "timelinePeriod":   { "size": 11, "bold": true,  "color": "$colors.primary.500" },
        "timelineTitle":    { "size": 13, "bold": true,  "color": "$colors.neutral.900" },
        "timelineDesc":     { "size": 11, "bold": false, "lineSpacingPt": 17, "color": "$colors.neutral.400" },

        "quoteMark":        { "size": 56, "bold": true,  "color": "$colors.primary.500" },
        "quoteBody":        { "size": 22, "bold": false, "lineSpacingPt": 33, "color": "$colors.neutral.0" },
        "quoteAuthor":      { "size": 16, "bold": true,  "color": "$colors.primary.500" },
        "quoteRole":        { "size": 12, "bold": false, "color": "$colors.neutral.400" },

        "tableHeader":      { "size": 12, "bold": true,  "color": "$colors.neutral.0" },
        "tableCell":        { "size": 11, "bold": false },
        "tableCellFirst":   { "size": 11, "bold": false, "color": "$colors.neutral.900" },
        "tableNote":        { "size": 10, "bold": false, "color": "$colors.neutral.400" },

        "closingMessage":   { "size": 50, "bold": true,  "color": "gradient:title" },
        "closingContact":   { "size": 14, "bold": false, "color": "$colors.neutral.400" },
        "footerLabel":      { "size":  8, "bold": false, "color": "$colors.neutral.200" },
        "footerPageNum":    { "size": 10, "bold": false, "color": "$colors.neutral.400" }
      }
    }
  },

  "spacing": {
    "xxs": 4,
    "xs": 8,
    "s": 12,
    "m": 16,
    "l": 24,
    "xl": 32,
    "xxl": 48,
    "xxxl": 64
  },

  "radius": {
    "none": 0,
    "xs": 2,
    "sm": 4,
    "base": 6,
    "md": 8,
    "lg": 10,
    "xl": 12,
    "2xl": 16,
    "3xl": 20,
    "full": "50%"
  },

  "shadow": {
    "none": "none",
    "xs": "0 1px 2px rgba(0,0,0,0.05)",
    "sm": "0 1px 3px rgba(0,0,0,0.10), 0 1px 2px rgba(0,0,0,0.06)",
    "md": "0 2px 8px rgba(0,0,0,0.10)",
    "lg": "0 4px 16px rgba(0,0,0,0.12)",
    "xl": "0 8px 32px rgba(0,0,0,0.15)",
    "2xl": "0 12px 40px rgba(0,0,0,0.18)",
    "3xl": "0 16px 48px rgba(0,0,0,0.20)",
    "primary": "0 4px 15px rgba(10,125,107,0.20)",
    "danger": "0 4px 15px rgba(214,67,59,0.25)"
  },

  "border": {
    "width": { "none": 0, "thin": "1px", "thick": "2px", "accent": "3px" },
    "style": { "solid": "solid", "dashed": "dashed", "dotted": "dotted" },
    "color": {
      "default": "#EAECF0",
      "subtle":  "#D0D5DD",
      "primary": "#3EC99E",
      "success": "#53AF36",
      "warning": "#F3B021",
      "danger": "#F12D2D"
    }
  },

  "gradients": {
    "avatar": {
      "red": "linear-gradient(135deg, #ff6d6d 0%, #ff1414 70%, #FFB928 100%)",
      "yellow": "linear-gradient(135deg, #DDED85 0%, #C8E13C 70%, #64D241 100%)",
      "green": "linear-gradient(135deg, #B2E9A0 0%, #64D241 75%, #41D2A5 100%)",
      "teal": "linear-gradient(135deg, #A0E9D2 0%, #41D2A5 70%, #3CC5CF 100%)",
      "purple": "linear-gradient(135deg, #B195EC 0%, #8255E1 70%, #764DCD 100%)",
      "orange": "linear-gradient(135deg, #FFCA59 0%, #FFB928 70%, #E6A71A 100%)"
    },
    "card": {
      "red": "linear-gradient(135deg, #ff6d6d 0%, #ff1414 100%)",
      "yellow": "linear-gradient(135deg, #DDED85 0%, #C8E13C 100%)",
      "green": "linear-gradient(135deg, #B2E9A0 0%, #64D241 100%)",
      "teal": "linear-gradient(135deg, #A0E9D2 0%, #41D2A5 100%)",
      "purple": "linear-gradient(135deg, #B195EC 0%, #8255E1 100%)",
      "orange": "linear-gradient(135deg, #FFCA59 0%, #FFB928 100%)"
    }
  },

  "charts": {
    "palette": ["#53AF36", "#007BFF", "#3CC5CF", "#8255E1", "#FFB928", "#F12D2D"],
    "style": "minimal",
    "showGrid": false,
    "labelColor": "#3D444A",
    "axisColor": "#D0D5DD",
    "fillOpacity": 0.3
  },

  "logo": {
    "horizontalPrimary": "assets/logo-horizontal-primary.svg",
    "horizontalReverse": "assets/logo-horizontal-reverse.svg",
    "stackedPrimary": "assets/logo-stacked-primary.svg",
    "stackedReverse": "assets/logo-stacked-reverse.svg",
    "safetyMargin": "1x text-height",
    "minWidthPx": 80
  },


  "media": {
    "ppt": {
      "slideRatio": "16:9",
      "safeMargin": 48,
      "gridColumns": 12,
      "coverBgColor": "#F8FAFC",
      "coverBgColorDark": "#0E1216",
      "dividerBgColor": "#3EC99E",
      "fontSizeTitle": "h1",
      "fontSizeBody": "body1"
    },
    "docx": {
      "pageSize": "A4",
      "margin": { "top": 25.4, "bottom": 25.4, "left": 31.7, "right": 31.7 },
      "heading1": { "size": 28, "color": "#0E1216" },
      "heading2": { "size": 22, "color": "#0E1216" },
      "heading3": { "size": 18, "color": "#3EC99E" },
      "tableHeaderBg": "#3EC99E",
      "tableHeaderColor": "#F8FAFC",
      "tableBorderColor": "#D0D5DD",
      "tableStripeBg": "#F2F3F5"
    },
    "pdf": {
      "pageSize": "A4",
      "margin": { "top": 20, "bottom": 20, "left": 25, "right": 25 },
      "headerLogoVariant": "horizontal-primary",
      "headerLogoMaxHeightMm": 10,
      "footerTextColor": "#8A9199",
      "codeFontFamily": "JetBrains Mono",
      "codeFontSize": 10,
      "codeBgColor": "#F2F3F5"
    }
  }
}
