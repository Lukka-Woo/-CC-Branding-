# ── 项目专属内容（本地保留，不上传）────────────────────────────────────────
projects/

# ── 系统产物（可重新生成，不入版本库）──────────────────────────────────────
.generated/

# ── 构建临时文件 ─────────────────────────────────────────────────────────────
*.tmp.docx
*.bak
.~lock.*          # LibreOffice / WPS 文件锁

# ── 依赖包（npm install 可重新生成）──────────────────────────────────────────
node_modules/

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.Python
*.egg-info/

# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
._*
